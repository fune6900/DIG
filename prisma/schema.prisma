generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Ootd {
  id            String   @id @default(uuid())
  imageUrl      String
  oneLiner      String
  colorPalette  Json
  styles        Json
  description   String
  detectedItems Json
  radarScores   Json?
  date          DateTime @default(now())
  tags          String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stickerUrl    String?

  @@index([date])
}
