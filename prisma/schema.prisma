generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Knowledge {
  id                   String   @id @default(uuid())
  brand                String
  category             String
  era                  String
  description          String?
  tags                 String[]
  identificationPoints Json
  imageUrls            String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([brand])
  @@index([category])
  @@index([era])
}

model Ootd {
  id            String   @id @default(uuid())
  imageUrl      String
  oneLiner      String
  colorPalette  Json
  styles        Json
  description   String
  detectedItems Json
  date          DateTime @default(now())
  tags          String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stickerUrl    String?

  @@index([date])
}
