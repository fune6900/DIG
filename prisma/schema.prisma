// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Knowledge {
  id                   String   @id @default(uuid())
  brand                String
  category             String
  era                  String
  description          String?
  tags                 String[]
  identificationPoints Json
  imageUrls            String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([brand])
  @@index([category])
  @@index([era])
}
