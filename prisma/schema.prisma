// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Knowledge {
  id                   String   @id @default(uuid())
  brand                String
  category             String
  era                  String
  description          String?
  tags                 String[]
  identificationPoints Json
  imageUrls            String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([brand])
  @@index([category])
  @@index([era])
}

model Ootd {
  id            String   @id @default(uuid())
  imageUrl      String
  oneLiner      String
  colorPalette  Json     // Array<{name: string, colorCode: string, percentage: number}>
  styles        Json     // Array<{name: string, percentage: number}>
  description   String
  detectedItems Json     // Array<{name: string, imageHint?: string}>
  date          DateTime @default(now())
  tags          String[] // max 3
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}
